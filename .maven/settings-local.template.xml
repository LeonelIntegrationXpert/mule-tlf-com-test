          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.0.0 https://maven.apache.org/xsd/settings-1.0.0.xsd">

  <!--
    Template local. Copie para .maven/settings-local.xml se precisar testar Maven localmente.
    Não commitar settings-local.xml com credenciais reais.
  -->

  <interactiveMode>false</interactiveMode>

  <servers>
